# MzAgent Web 启动脚本示例环境变量
# 使用方式：
#   cp scripts/start_web.example.env .env
#   再按你的实际服务修改下面字段

# Web 启动参数
MZ_AGENT_WEB_HOST=127.0.0.1
MZ_AGENT_WEB_PORT=8000
MZ_AGENT_WEB_PROFILE=proxy-demo
MZ_AGENT_WEB_LIVE_LLM=1

# 兼容旧配置读取的默认 LLM 字段
# 如果你还没有通过页面创建 profile，系统会先用这组默认值生成 default profile
LLM_MODEL_ID=gpt-4o-mini
LLM_API_KEY=sk-your-key
LLM_BASE_URL=https://your-proxy.example.com/v1
LLM_TIMEOUT=60

# 如果你打算使用原生 OpenAI，可将 LLM_BASE_URL 留空：
# LLM_MODEL_ID=gpt-4o-mini
# LLM_API_KEY=sk-your-openai-key
# LLM_BASE_URL=
